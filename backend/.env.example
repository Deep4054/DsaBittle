# DSA Dopamine Engine — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file — it is in .gitignore

# ── NVIDIA NIM (Required) ──
# Get your key at: https://build.nvidia.com → API Keys
NVIDIA_NIM_API_KEY=nvapi-YOUR_KEY_HERE

# ── Server ──
PORT=8000
