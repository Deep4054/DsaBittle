{
  "manifest_version": 3,
  "name": "DSA Dopamine Engine",
  "version": "1.1.0",
  "description": "Track DSA progress with real-world AI insights, streak tracking, and personalized coaching.",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.hackerrank.com/*",
    "http://localhost:8000/*",
    "https://dsabittle-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://www.hackerrank.com/challenges/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["styles.css", "popup-glass.css", "icons/*", "dashboard.html", "dashboard.js"],
      "matches": ["https://leetcode.com/*", "https://www.hackerrank.com/*", "<all_urls>"]
    }
  ]
}
